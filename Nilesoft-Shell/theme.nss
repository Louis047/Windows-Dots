theme
{
	name="modern"
	view=auto
	border.enabled=true
	border.size=1
	border.radius=0
	border.color=#555555
	layout.popup=-1
	image.enabled=false
	item
	{
		prefix=0
		back
		{
			normal = #00000000
			normal.disabled = #00000000
			select = #00000000
			select.disabled = #00000000
		}
	}
	separator.margin=[8,2]
}