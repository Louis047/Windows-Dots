theme
{
	name = "auto"
	view = view.small
	dark = default
	
	background
	{
		color = auto
		opacity = 100
		effect = 1
	}
	
	item
	{
		radius = 0
		prefix = 0
		opacity = 100
	}

	border
	{
		enabled = true
		size = 1
		radius = 0
		color = auto
		opacity = 100
	}

	shadow
	{
		enabled = true
		size = 2
		opacity = 50
		offset = 0
	}

	separator
	{
		size = 1
	}

	image
	{
		enabled = false
	}
}