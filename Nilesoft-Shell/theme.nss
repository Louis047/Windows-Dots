theme
{
	name = "auto"
	view = view.compact
	dark = default
	
	background
	{
		color = auto
		opacity = 100
		effect = auto
	}
	
	item
	{
		radius = 0
		prefix = 0
		opacity = 100
		padding = 6
		margin = 0
	}

	border
	{
		enabled = true
		size = 1
		radius = 0
		color = auto
		opacity = 100
	}

	separator
	{
		size = 1
		color = auto
		opacity = 50
		margin = [2,2]
	}

	shadow
	{
		enabled = false
	}

	image
	{
		enabled = false
	}

	layout
	{
		popup = -1
	}

}